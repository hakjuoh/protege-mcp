@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://example.org/conformance#> .

<https://example.org/conformance> a owl:Ontology ;
    owl:versionIRI <https://example.org/conformance/1.0.0> ;
    owl:imports <https://example.org/conformance/module> .

ex:Term a owl:Class ;
    rdfs:label "Term"@en .

ex:relatedTo a owl:ObjectProperty ;
    rdfs:label "related to"@en .
