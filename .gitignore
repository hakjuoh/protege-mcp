# Build output
target/
__pycache__/
*.pyc
*.class

# Recon scratch (API-fact extraction, not source)
.recon/

# IDE
*.iml
.idea/
.vscode/
.project
.classpath
.settings/

# OS
.DS_Store

# Maven — ignore .mvn contents but NOT the directory itself, so specific files below can be
# re-included (git cannot re-include a file whose parent directory is excluded, so the wrapper
# directory must be re-included before the file inside it).
.mvn/*
!.mvn/wrapper/
.mvn/wrapper/*
!.mvn/wrapper/maven-wrapper.properties
# Tracked: anchors ${maven.multiModuleProjectDirectory} to the repo root (the plugin's surefire
# working directory and the reactor's root-anchor enforcer rule both resolve against it).
!.mvn/extensions.xml
