<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.0"?>
<plugin>

    <!-- Per-EditorKit lifecycle: starts/stops the embedded MCP HTTP server.
         The extension 'id' is the unique, non-null hook id used as the key in the
         EditorKit's disposable registry (a duplicate/null id would orphan the hook
         and skip its dispose()). -->
    <extension id="McpServerHook"
               point="org.protege.editor.core.application.EditorKitHook">
        <class value="io.github.hakjuoh.McpServerHook"/>
        <editorKitId value="OWLEditorKit"/>
    </extension>

    <!-- Status view: bound URL/port/token, read-only indicator, regenerate-token. -->
    <extension id="McpServerView"
               point="org.protege.editor.core.application.ViewComponent">
        <label value="MCP Server"/>
        <class value="io.github.hakjuoh.ui.McpServerView"/>
    </extension>

    <!-- Preferences tab: port, autostart, bearer token, write-confirm, read-only. -->
    <extension id="io.github.hakjuoh.preferences"
               point="org.protege.editor.core.application.preferencespanel">
        <label value="MCP"/>
        <class value="io.github.hakjuoh.ui.McpPreferencesPanel"/>
    </extension>

    <!-- In-Protégé chat assistant (Architecture Approach B): drives a local coding-agent CLI that
         connects back to this plugin's MCP server to read/edit the live ontology.
         The extension id 'ChatView' becomes the fully-qualified view id 'io.github.hakjuoh.ChatView'
         referenced by viewconfig-ontologyassistanttab.xml. -->
    <extension id="ChatView"
               point="org.protege.editor.core.application.ViewComponent">
        <label value="Ontology Assistant"/>
        <class value="io.github.hakjuoh.ui.ChatView"/>
    </extension>

    <!-- Dedicated top-level tab hosting the Ontology Assistant view (reuses the generic OWL views tab + a
         default layout). -->
    <extension id="OntologyAssistantTab"
               point="org.protege.editor.core.application.WorkspaceTab">
        <label value="Ontology Assistant"/>
        <class value="io.github.hakjuoh.ui.ChatTab"/>
        <editorKitId value="OWLEditorKit"/>
        <index value="Z"/>
        <defaultViewConfigFileName value="viewconfig-ontologyassistanttab.xml"/>
    </extension>

    <!-- Preferences tab for the chat: CLI path overrides + egress consent reset. -->
    <extension id="io.github.hakjuoh.chat.preferences"
               point="org.protege.editor.core.application.preferencespanel">
        <label value="Ontology Assistant"/>
        <class value="io.github.hakjuoh.ui.ChatPreferencesPanel"/>
    </extension>

</plugin>
