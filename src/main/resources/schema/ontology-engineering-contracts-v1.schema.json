{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakjuoh.github.io/protege-mcp/schema/ontology-engineering-contracts-v1.schema.json",
  "title": "Protégé MCP ontology-engineering contracts v1",
  "description": "JSON contracts for the foundational project, revision, finding, stage and gate Java records. Unknown top-level fields are rejected.",
  "oneOf": [
    {"$ref": "#/$defs/projectCoordinates"},
    {"$ref": "#/$defs/modelRevision"},
    {"$ref": "#/$defs/finding"},
    {"$ref": "#/$defs/artifactReference"},
    {"$ref": "#/$defs/stageResult"},
    {"$ref": "#/$defs/gateResult"}
  ],
  "$defs": {
    "projectCoordinates": {
      "type": "object",
      "required": ["project_id", "policy_version", "root_ontology", "modules"],
      "additionalProperties": false,
      "properties": {
        "project_id": {"$ref": "#/$defs/nonEmptyString"},
        "policy_version": {"type": "integer", "minimum": 1},
        "root_ontology": {"$ref": "#/$defs/iri"},
        "modules": {
          "type": "array",
          "items": {"$ref": "#/$defs/iri"},
          "uniqueItems": true
        }
      }
    },
    "modelRevision": {
      "type": "object",
      "required": ["workspace_id", "session_revision", "semantic_fingerprint", "document_fingerprint"],
      "additionalProperties": false,
      "properties": {
        "workspace_id": {"type": "string", "format": "uuid"},
        "session_revision": {"type": "integer", "minimum": 0},
        "semantic_fingerprint": {"$ref": "#/$defs/fingerprint"},
        "document_fingerprint": {"$ref": "#/$defs/fingerprint"}
      }
    },
    "finding": {
      "type": "object",
      "required": ["id", "source", "severity", "message", "focus_iri", "axiom", "path", "rule_id", "waiver", "details"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/nonEmptyString"},
        "source": {"$ref": "#/$defs/nonEmptyString"},
        "severity": {"enum": ["info", "warning", "error"]},
        "message": {"$ref": "#/$defs/nonEmptyString"},
        "focus_iri": {"oneOf": [{"$ref": "#/$defs/iri"}, {"type": "null"}]},
        "axiom": {"type": ["string", "null"]},
        "path": {"type": ["string", "null"]},
        "rule_id": {"oneOf": [{"$ref": "#/$defs/nonEmptyString"}, {"type": "null"}]},
        "waiver": {"type": ["object", "null"]},
        "details": {"type": "object"}
      }
    },
    "artifactReference": {
      "type": "object",
      "required": ["path", "sha256", "bytes", "details"],
      "additionalProperties": false,
      "properties": {
        "path": {"$ref": "#/$defs/nonEmptyString"},
        "sha256": {"$ref": "#/$defs/digest"},
        "bytes": {"type": "integer", "minimum": 0},
        "details": {"type": "object"}
      }
    },
    "stageResult": {
      "type": "object",
      "required": ["stage", "status", "message", "findings", "details"],
      "additionalProperties": false,
      "properties": {
        "stage": {"$ref": "#/$defs/nonEmptyString"},
        "status": {"enum": ["pass", "fail", "error", "skipped"]},
        "message": {"type": ["string", "null"]},
        "findings": {
          "type": "array",
          "items": {"$ref": "#/$defs/finding"}
        },
        "details": {"type": "object"}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"enum": ["error", "skipped"]}}},
          "then": {"properties": {"message": {"$ref": "#/$defs/nonEmptyString"}}}
        }
      ]
    },
    "gateResult": {
      "type": "object",
      "required": ["gate", "policy_version", "semantic_fingerprint", "required_stages", "stages_ran", "stages_skipped", "stages", "findings", "artifacts", "details"],
      "additionalProperties": false,
      "properties": {
        "gate": {"enum": ["pass", "fail", "error"]},
        "policy_version": {"type": "integer", "minimum": 1},
        "semantic_fingerprint": {"$ref": "#/$defs/fingerprint"},
        "required_stages": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/nonEmptyString"},
          "uniqueItems": true
        },
        "stages_ran": {"type": "integer", "minimum": 0},
        "stages_skipped": {"type": "integer", "minimum": 0},
        "stages": {
          "type": "array",
          "items": {"$ref": "#/$defs/stageResult"}
        },
        "findings": {
          "type": "array",
          "items": {"$ref": "#/$defs/finding"}
        },
        "artifacts": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifactReference"}
        },
        "details": {"type": "object"}
      }
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "iri": {
      "type": "string",
      "format": "uri",
      "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:"
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
